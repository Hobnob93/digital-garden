{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File",
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithEnvironmentName"
    ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.RenderedCompactJsonFormatter, Serilog.Formatting.Compact"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "/app/logs/app-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://seq:5341"
        }
      }
    ]
  },

  "AllowedOrigin": "https://khobdey.co.uk",

  "LastFm": {
    "BaseAddress": "http://ws.audioscrobbler.com/2.0/",
    "TopArtistsEndpoint": "?method=user.gettopartists&user={0}&period=6month&limit=8&api_key={1}&format=json",
    "TopTracksEndpoint": "?method=user.gettoptracks&user={0}&period=6month&limit=8&api_key={1}&format=json",
    "UserId": "pilot_master"
  },

  "Steam": {
    "BaseAddress": "https://api.steampowered.com",
    "Endpoints": {
      "GetOwnedGames": "/IPlayerService/GetOwnedGames/v0001?key={0}&steamid={1}&format=json&include_appinfo=1&include_played_free_games=1",
      "GetPlayerAchievements": "/ISteamUserStats/GetPlayerAchievements/v0001?key={0}&steamid={1}&format=json&appid={2}",
      "GetSchemaForGame": "/ISteamUserStats/GetSchemaForGame/v0002/?key={0}&steamid={1}&format=json&appid={2}",
      "GetGlobalGameAchievements": "ISteamUserStats/GetGlobalAchievementPercentagesForApp/v0002/?key={0}&steamid={1}&format=json&appid={2}&gameid={3}"
    }
  },

  "DailyIngest": {
    "MinimumDelayMinutes": 5,
    "DelayInDays": 1
  },

  "GeneralFlags": {
    "IsWip": false
  }
}
