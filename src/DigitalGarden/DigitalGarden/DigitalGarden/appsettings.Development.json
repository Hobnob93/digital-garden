{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.RenderedCompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ]
  },

  "DailyIngest": {
    "MinimumDelayMinutes": 0.2,
    "DelayInDays": 0.1
  },

  "Steam": {
    "MaxFullUpdates": 10
  },

  "AllowedOrigin": "https://localhost:7052",
  "DetailedErrors": true
}
