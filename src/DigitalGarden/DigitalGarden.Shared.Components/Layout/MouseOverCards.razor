@if (Cards is null && !DisableSpinner)
{
    <div class="w-100">
        <PlanetSpinner />
    </div>
}

@if (Cards is not null)
{
    <div class="mouse-over-cards horizontal mt-2" @ref="_mouseOverCardsRoot">
        @foreach (var card in Cards)
        {
            <div class="card">
                <div class="icon-container">
                    <i class="@card.FontAwesomeType @card.FontAwesomeIcon fa-xl"></i>
                </div>
                <div class="info-container">
                    <h6>@card.Title</h6>
                    @if (!string.IsNullOrWhiteSpace(card.Description))
                    {
                        <p class="muted mt-2">@card.Description</p>
                    }
                </div>
            </div>
        }
    </div>
}